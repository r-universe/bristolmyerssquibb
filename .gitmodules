[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "blockr"]
	path = blockr
	url = https://github.com/bristolmyerssquibb/blockr
[submodule "blockr.core"]
	path = blockr.core
	url = https://github.com/bristolmyerssquibb/blockr.core
[submodule "blockr.dag"]
	path = blockr.dag
	url = https://github.com/bristolmyerssquibb/blockr.dag
[submodule "blockr.dock"]
	path = blockr.dock
	url = https://github.com/bristolmyerssquibb/blockr.dock
[submodule "blockr.dplyr"]
	path = blockr.dplyr
	url = https://github.com/bristolmyerssquibb/blockr.dplyr
[submodule "blockr.ggplot"]
	path = blockr.ggplot
	url = https://github.com/bristolmyerssquibb/blockr.ggplot
[submodule "blockr.io"]
	path = blockr.io
	url = https://github.com/bristolmyerssquibb/blockr.io
[submodule "blockr.theme"]
	path = blockr.theme
	url = https://github.com/BristolMyersSquibb/blockr.theme
	registered = false
[submodule "blockr.ui"]
	path = blockr.ui
	url = https://github.com/BristolMyersSquibb/blockr.ui
	registered = false
[submodule "g6R"]
	path = g6R
	url = https://github.com/cynkra/g6R
	registered = false
[submodule "shinytest2"]
	path = shinytest2
	url = https://github.com/nbenn/shinytest2
	branch = wait-for-app-serving
	registered = false
